{
  "name": "material-shortage-agent",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "@cap-js/mcp": "^1.2.0",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4",
    "@sap/cds": "^10"
  },
  "devDependencies": {
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.18.0",
    "@cap-js/sqlite": "^3",
    "@types/node": "^24.0.0",
    "tsx": "^4",
    "typescript": "^7.0.0"
  },
  "scripts": {
    "start": "cds-serve",
    "local-watch": "cds watch --port 4004",
    "start-mcp": "npx @modelcontextprotocol/inspector"
  },
  "private": true,
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "cds": {
    "mcp": {
      "per_action_tool": false,
      "toon_format": true
    },
    "requires": {
      "API_MATERIAL_STOCK_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/API_MATERIAL_STOCK_SRV",
        "credentials": {
          "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_MATERIAL_STOCK_SRV"
        }
      },
      "API_PRODUCTION_ORDER_2_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/API_PRODUCTION_ORDER_2_SRV",
        "credentials": {
          "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_PRODUCTION_ORDER_2_SRV"
        }
      },
      "API_PRODUCT_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/API_PRODUCT_SRV",
        "credentials": {
          "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_PRODUCT_SRV"
        }
      }
    }
  }
}
